# =============================================================
# Configuração do Backend — Recebimentos Marketplaces
# Copiar este ficheiro para .env e ajustar os valores
# =============================================================

# Base de dados DuckDB (caminho relativo à pasta backend/)
DATABASE_PATH=data/warehouse.duckdb

# Janela de dias para matching TRF vs ciclos de pagamento (padrão: 7)
TRF_WINDOW_DAYS=7

# CORS: origens permitidas separadas por vírgula
# Desenvolvimento:  CORS_ORIGINS=*
# Produção:         CORS_ORIGINS=https://meusite.com,https://app.meusite.com
CORS_ORIGINS=*

# Logging detalhado (true = imprime headers e tempos; false = só erros críticos)
# Desenvolvimento:  DEBUG_LOGGING=true
# Produção:         DEBUG_LOGGING=false
DEBUG_LOGGING=true

# Chave Fernet para encriptar senhas na aba Acessos (supplier_access).
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=<colar_aqui_o_valor_gerado>
